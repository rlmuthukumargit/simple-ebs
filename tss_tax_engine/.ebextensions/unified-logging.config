files:
  "/tmp/cw-unified-config.json":
    mode: "000600"
    owner: root
    group: root
    content: |
      {
        "logs": {
          "logs_collected": {
            "files": {
              "collect_list": [
                {
                  "file_path": "/var/log/eb-engine.log",
                  "log_group_name": "/aws/elasticbeanstalk/my-eb-env-dev/unified",
                  "log_stream_name": "{instance_id}/eb-engine"
                },
                {
                  "file_path": "/var/log/eb-hooks.log",
                  "log_group_name": "/aws/elasticbeanstalk/my-eb-env-dev/unified",
                  "log_stream_name": "{instance_id}/eb-hooks"
                },
                {
                  "file_path": "/var/log/nginx/access.log",
                  "log_group_name": "/aws/elasticbeanstalk/my-eb-env-dev/unified",
                  "log_stream_name": "{instance_id}/nginx-access"
                },
                {
                  "file_path": "/var/log/nginx/error.log",
                  "log_group_name": "/aws/elasticbeanstalk/my-eb-env-dev/unified",
                  "log_stream_name": "{instance_id}/nginx-error"
                },
                {
                  "file_path": "/var/log/web.stdout.log",
                  "log_group_name": "/aws/elasticbeanstalk/my-eb-env-dev/unified",
                  "log_stream_name": "{instance_id}/web-stdout"
                }
              ]
            }
          }
        }
      }

container_commands:
  01_append_logs_config:
    command: /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl -a append-config -m ec2 -c file:/tmp/cw-unified-config.json -s
